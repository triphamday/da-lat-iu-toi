GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=

# LLM provider config. GreenNode AIP is OpenAI-compatible.
# GreenNode AIP base URL:
# LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Knowledge and report paths inside this project/container.
KNOWLEDGE_DIR=knowledge
REPORT_DIR=reports

# Future vector database settings.
CHROMA_DIR=.agentbase/chroma
EMBEDDING_MODEL=
